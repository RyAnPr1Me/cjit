        -:  348:/**
        -:  349: * Route a compile task to the owning thread's queue and signal a waiter.
        -:  350: *
        -:  351: * Routing by (func_id % num_threads) gives each function affinity to one
        -:  352: * compiler thread.  That means the per-entry compile_lock is almost always
        -:  353: * acquired by the same thread, eliminating cross-thread trylock contention
        -:  354: * in the common case.
        -:  355: *
        -:  356: * Two-level priority:
        -:  357: *   priority >= 2 → priority queue (lane 1): T2 upgrades, manual requests.
        -:  358: *   priority  < 2 → normal queue   (lane 0): background monitoring promotions.
        -:  359: *
        -:  360: * The condvar signal is sent inside a brief mutex section so no wake-up can
        -:  361: * be lost (see engine struct comment for the full protocol).
        -:  362: *
        -:  363: * @return true if the task was accepted, false if the target queue is full.
        -:  364: */
      115:  365:static bool engine_enqueue_task(cjit_engine_t *engine,
        -:  366:                                 const compile_task_t *task)
        -:  367:{
      115:  368:    uint32_t n      = engine->cfg.compiler_threads;
      115:  369:    uint32_t target = task->func_id % n;
      115:  370:    uint32_t lane   = (task->priority >= 2) ? 1u : 0u;
      115:  371:    bool ok = mpmc_enqueue(&engine->work_queues[2 * target + lane], task);
      115:  372:    if (ok) {
      115:  373:        pthread_mutex_lock(&engine->work_cond_mutex);
      115:  374:        pthread_cond_signal(&engine->work_cond);
      115:  375:        pthread_mutex_unlock(&engine->work_cond_mutex);
        -:  376:    }
      115:  377:    return ok;
        -:  378:}
