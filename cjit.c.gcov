        -:  338:/* ══════════════════════════ internal helpers ══════════════════════════════ */
        -:  339:
        -:  340:/* Monotonic timestamp in milliseconds (shared by monitor helpers). */
     1467:  341:static uint64_t engine_now_ms(void)
        -:  342:{
        -:  343:    struct timespec ts;
     1467:  344:    clock_gettime(CLOCK_MONOTONIC, &ts);
