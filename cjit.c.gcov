        -:  286:
        -:  287:    /* Global statistics (relaxed atomics; no strict ordering needed). */
        -:  288:    atomic_uint_fast64_t stat_compilations;
        -:  289:    atomic_uint_fast64_t stat_failed;
        -:  290:    atomic_uint_fast64_t stat_timeouts;          /**< Compiler subprocess timeouts.  */
        -:  291:    atomic_uint_fast64_t stat_swaps;
        -:  292:    atomic_uint_fast64_t stat_tier_skips;        /**< O0→O3 tier-skip promotions. */
        -:  293:    atomic_uint_fast64_t stat_predictive_promos; /**< Slope-lookahead early promotions. */
        -:  294:
        -:  295:    /**
