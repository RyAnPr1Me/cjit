        -:  153:/* ══════════════════════ per-thread TLS batch counters ════════════════════ */
        -:  154:
        -:  155:/*
        -:  156: * Per-calling-thread call-count batch array.
        -:  157: *
        -:  158: * Each calling thread maintains a private uint8_t counter for every
        -:  159: * registered function.  On every call, only this thread-local byte is
        -:  160: * incremented (no shared-memory write, no atomic, no cache-line ownership
        -:  161: * transfer).  When the counter reaches CJIT_TLS_FLUSH_THRESHOLD, the
        -:  162: * accumulated count is flushed to the global atomic call_cnt with a
        -:  163: * single relaxed fetch_add and the local counter is reset to zero.
        -:  164: *
        -:  165: * Declared extern in cjit.h so that the CJIT_SHOULD_SAMPLE / CJIT_SAMPLE_ARGS
        -:  166: * macros can read it inline without a function call.  The cjit_tls_elapsed
        -:  167: * array remains private to this translation unit.
        -:  168: *
        -:  169: * uint8_t × CJIT_MAX_FUNCTIONS = 1 024 bytes of TLS per calling thread.
        -:  170: * TLS variables are zero-initialised by the C runtime.
        -:  171: */
        -:  172:__thread uint8_t  cjit_tls_counts[CJIT_MAX_FUNCTIONS];
        -:  173:
        -:  174:/*
        -:  175: * Per-calling-thread elapsed-nanoseconds accumulator.
        -:  176: *
        -:  177: * When CJIT_DISPATCH_TIMED or cjit_record_timed_call() is used, the
        -:  178: * measured nanoseconds for each call are added here.  The buffer is
        -:  179: * flushed to the global atomic total_elapsed_ns alongside cjit_tls_counts
        -:  180: * — both share the same CJIT_TLS_FLUSH_THRESHOLD trigger — so only one
        -:  181: * additional atomic_fetch_add per THRESHOLD calls is required beyond the
        -:  182: * normal call_cnt flush.
        -:  183: *
        -:  184: * uint64_t × CJIT_MAX_FUNCTIONS = 8 192 bytes of TLS per calling thread.
        -:  185: * Zero-initialised; stays zero for functions not dispatched via timed paths.
        -:  186: */
        -:  187:static __thread uint64_t cjit_tls_elapsed[CJIT_MAX_FUNCTIONS];
