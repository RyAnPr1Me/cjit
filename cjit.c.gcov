        -:  259:    pthread_cond_t  work_cond;
        -:  260:
        -:  261:    /* Deferred GC for safe dlclose of retired handles. */
        -:  262:    deferred_gc_t   dgc;
        -:  263:
        -:  264:    /*
        -:  265:     * Background thread handles and per-thread arguments.
