        -:  239:    mpmc_queue_t   *work_queues;   /* [2 × cfg.compiler_threads]: [0]=normal [1]=prio */
        -:  240:
        -:  241:    /*
        -:  242:     * Shared condition variable.
        -:  243:     *
        -:  244:     * Any enqueue into any per-thread queue signals one waiting compiler
        -:  245:     * thread via this condvar.  Protocol:
        -:  246:     *
        -:  247:     *   Producer (engine_enqueue_task):
