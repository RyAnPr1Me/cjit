        -:  831:            "║  Cache hits       : %6llu                ║\n"
        -:  832:            "║  Cache misses     : %6llu                ║\n"
        -:  833:            "║  Disk writes      : %6llu                ║\n"
        -:  834:            "║  Disk reads       : %6llu                ║\n"
        -:  835:            "║  LRU evictions    : %6llu                ║\n"
        -:  836:            "║  Pressure evicts  : %6llu                ║\n"
        -:  837:            "║  Promotions       : %6llu                ║\n"
        -:  838:            "╚══════════════════════════════════════════╝\n",
    #####:  839:            pnames[s.pressure],
    #####:  840:            (unsigned long long)s.mem_available_mb,
    #####:  841:            (unsigned long long)s.mem_total_mb,
        -:  842:            s.total_registered,
        -:  843:            s.hot_count, s.warm_count, s.cold_count,
    #####:  844:            (unsigned long long)s.cache_hits,
    #####:  845:            (unsigned long long)s.cache_misses,
    #####:  846:            (unsigned long long)s.disk_writes,
    #####:  847:            (unsigned long long)s.disk_reads,
    #####:  848:            (unsigned long long)s.evictions,
    #####:  849:            (unsigned long long)s.pressure_evictions,
    #####:  850:            (unsigned long long)s.promotions);
    #####:  851:}
